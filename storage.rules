rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['super_admin', 'editor'];
    }

    function isSuperAdmin() {
      return isAdmin() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    match /news/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /media/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /site/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /ai-media/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /ai-voice-video/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if request.time < timestamp.date(2026, 5, 15);
    }
  }
}
