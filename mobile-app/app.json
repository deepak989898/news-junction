{
  "expo": {
    "name": "News Junction",
    "slug": "news-junction-mobile",
    "version": "1.0.0",
    "scheme": "newsjunction",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.newsjunction.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.newsjunction.mobile",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-secure-store",
      "expo-localization",
      "expo-local-authentication",
      [
        "expo-screen-capture",
        {
          "captureType": "prevent"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "replace-with-eas-project-id"
      },
      "release": {
        "rollbackDoc": "docs/RELEASE_GUIDE.md#rollback-plan"
      }
    }
  }
}
