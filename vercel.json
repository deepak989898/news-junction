{
  "functions": {
    "src/app/api/automation/trigger/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/automation/approve/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/cron/process-news/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/fetch-news/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/process-social-queue/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/ai/social/publish-now/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/fetch-news",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/process-news",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/process-social-queue",
      "schedule": "30 4 * * *"
    }
  ]
}
