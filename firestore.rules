rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userDoc().data.role in ['super_admin', 'editor'];
    }

    function isSuperAdmin() {
      return isAdmin() && userDoc().data.role == 'super_admin';
    }

    match /news/{newsId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /settings/{settingId} {
      allow read: if settingId in ['site', 'general'] || isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /aiPromptTemplates/{templateId} {
      allow read: if isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /aiContentLogs/{logId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /aiPendingChanges/{changeId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /seoInternalLinkSuggestions/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /seoTopicSuggestions/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /aiSeoLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /mediaAssets/{assetId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /mediaGenerationQueue/{queueId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /aiMediaLogs/{logId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /socialAccounts/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /socialCampaigns/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /socialPostQueue/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /socialTemplates/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /socialAnalytics/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /socialLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /audioAssets/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /subtitleAssets/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /videoPackages/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /newsDigests/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /voiceVideoLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /editorialReviews/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /editorialLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /editorialQueue/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /analyticsSnapshots/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /growthRecommendations/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /trendSuggestions/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /contentPerformance/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /revenueReports/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /analyticsReports/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /analyticsLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /userPreferences/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isSuperAdmin();
    }

    match /userFollows/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isSuperAdmin();
    }

    match /userReadingHistory/{docId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isSuperAdmin();
    }

    match /userBookmarks/{docId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /personalizedRecommendations/{docId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isSuperAdmin();
    }

    match /userDigests/{docId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isSuperAdmin();
    }

    match /personalizationLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /systemLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /operationLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /queueLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /cronLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /healthChecks/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /sources/{sourceId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /media/{mediaId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /adSlots/{slotId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /rawNews/{rawNewsId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /automationLogs/{logId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isSuperAdmin();
    }
  }
}
