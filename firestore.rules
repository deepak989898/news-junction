rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userDoc().data.role in ['super_admin', 'editor'];
    }

    function isSuperAdmin() {
      return isAdmin() && userDoc().data.role == 'super_admin';
    }

    match /news/{newsId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create: if isAdmin();
      // Admins can fully edit. Anyone may bump the public view counter on a
      // published article, but ONLY the `views` field — nothing else.
      allow update: if isAdmin()
        || (
          resource.data.status == 'published' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
        );
      allow delete: if isSuperAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /settings/{settingId} {
      allow read: if settingId in ['site', 'general'] || isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /aiPromptTemplates/{templateId} {
      allow read: if isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /aiContentLogs/{logId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /aiPendingChanges/{changeId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /seoInternalLinkSuggestions/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /seoTopicSuggestions/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /aiSeoLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /mediaAssets/{assetId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /mediaGenerationQueue/{queueId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /aiMediaLogs/{logId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /socialAccounts/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /socialCampaigns/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /socialPostQueue/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /socialTemplates/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /socialAnalytics/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /socialLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /audioAssets/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /subtitleAssets/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /videoPackages/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /newsDigests/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /voiceVideoLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /editorialReviews/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /editorialLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /editorialQueue/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /analyticsSnapshots/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /growthRecommendations/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /trendSuggestions/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /contentPerformance/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /revenueReports/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /analyticsReports/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /analyticsLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /userPreferences/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isSuperAdmin();
    }

    match /userFollows/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isSuperAdmin();
    }

    match /userReadingHistory/{docId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isSuperAdmin();
    }

    match /userBookmarks/{docId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /personalizedRecommendations/{docId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isSuperAdmin();
    }

    match /userDigests/{docId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isSuperAdmin();
    }

    match /personalizationLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /systemLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /operationLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /queueLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /cronLogs/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /healthChecks/{docId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /sources/{sourceId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /media/{mediaId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /adSlots/{slotId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /rawNews/{rawNewsId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /automationLogs/{logId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // A signed-in user may create only their own doc, and may NOT grant
      // themselves an admin role. Admin roles are set via the Admin SDK
      // (server) or by an existing super_admin — never by self-signup.
      allow create: if isAuthenticated() &&
        request.auth.uid == userId &&
        (!('role' in request.resource.data) ||
          !(request.resource.data.role in ['super_admin', 'editor']));
      allow update, delete: if isSuperAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.text is string &&
        request.resource.data.articleId is string;
      allow update: if isAuthenticated() && (
        (resource.data.uid == request.auth.uid) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'reported']))
      );
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Mobile push registration — a user only manages their own token doc.
    match /userPushTokens/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Trust & Transparency: public policy pages (About, Editorial, Privacy, etc.).
    // Content is public; only admins may edit. Per-page super-admin gating for
    // legal/ownership pages is enforced server-side in the admin API.
    match /sitePages/{pageKey} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // Ownership, contact & legal configuration (public transparency details).
    match /trustSettings/{docId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    // Author profiles — publicly readable, admin-managed.
    match /authors/{authorId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Contact form submissions — NEVER publicly readable. Writes happen only via
    // the server (Admin SDK) through /api/contact, so client creates are denied.
    match /contactSubmissions/{submissionId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // Newsletter subscribers — server-only writes (subscribe/unsubscribe APIs).
    match /newsletterSubscribers/{subscriberId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // Newsletter send logs — admin read, server write.
    match /newsletterLogs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // Push delivery logs — admin read, server write.
    match /pushLogs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // Deny everything not explicitly matched above (no more open catch-all).
    // Server code uses the Admin SDK, which bypasses these rules entirely.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
